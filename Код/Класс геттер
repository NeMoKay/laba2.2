#include <iostream>

class Box {
   double length;   // ОБЛАСТЬ PRIVATE
   double width;    // имена по-прежнему видны
   double height;   // внутри класса
public:             // ИНТЕРФЕЙС КЛАССА
   void set_dimentions(double length_, double width_, double height_) {
       length = length_; width = width_; height = height_;
   }
   double get_volume() {
       std::cout << this <<": ";    // выведем указатель объекта
       return length * width * height;
   }
};  

int main() {
    Box my_box1, my_box2;
    my_box1.set_dimentions(2.5, 2.5, 2.5);
    my_box2.set_dimentions(3.5, 3.5, 3.5);
    std::cout << my_box1.get_volume() << "\n";
    std::cout << my_box2.get_volume() << "\n";
}