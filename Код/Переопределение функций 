

#include <iostream>
using namespace std;



template <typename T>

struct MathOperations {
    T a;
    T b;


    MathOperations(T new_a, T new_b){
        a = new_a;
        b = new_b;
    }

    T add(){
        return a + b;
    }
    T subtract(){
        return a - b;
    }
    T multiply(){
        return a * b;
    }
};

int main() {
    int a = 5, b = 3;
    double x = 2.5, y = 1.5;
    MathOperations<int> mathOperations1(a, b);

    cout << "Сумма целых чисел: " << mathOperations1.add() << endl;
    cout << "Разность целых чисел: " << mathOperations1.subtract() << endl;
    cout << "Произведение целых чисел: " << mathOperations1.multiply() << endl;

    MathOperations<double> mathOperations2(x, y);

    cout << "Сумма вещественных чисел: " << mathOperations2.add() << endl;
    cout << "Разность вещественных чисел: " << mathOperations2.subtract() << endl;
    cout << "Произведение вещественных чисел: " << mathOperations2.multiply() << endl;

    return 0;
}



